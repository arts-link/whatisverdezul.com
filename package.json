{
  "name": "whatisverdezul-com",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "cd themes/ryder && npm install",
    "build-tw": "npx tailwindcss -i ./themes/ryder/assets/css/main.css -o ./assets/css/tw-built.css",
    "deploy-tw": "npx tailwindcss -i ./themes/ryder/assets/css/main.css -o ./assets/css/tw-built.css --minify",
    "watch-tw": "npx tailwindcss -i ./themes/ryder/assets/css/main.css -o ./assets/css/tw-built.css -w"
  },
  "devDependencies": {
    "@alpinejs/csp": "^3.15.12",
    "@alpinejs/focus": "^3.15.12",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.19"
  }
}
